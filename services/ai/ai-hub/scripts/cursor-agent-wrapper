#!/bin/bash
# Cursor-agent wrapper for Docker container
#
# This wrapper solves 3 problems:
# 1. HOME environment - cursor-agent looks for config in $HOME/.cursor/
# 2. Version resolution - The actual binary is in a version-specific folder
# 3. PATH setup - Ensures the binary can find its co-located dependencies
#
# The cursor-agent is mounted from the host at /opt/cursor-agent/
# Auth configs are mounted at /root/.cursor/ and /root/.config/cursor/

set -e

# Set HOME for cursor-agent to find auth configs
export HOME=/root

# Find the latest version directory
VERSION_DIR=$(ls -1 /opt/cursor-agent/versions 2>/dev/null | head -1)

if [ -z "$VERSION_DIR" ]; then
    echo "Error: No cursor-agent version found in /opt/cursor-agent/versions/" >&2
    exit 1
fi

# Add the version directory to PATH for dependencies
export PATH="/opt/cursor-agent/versions/${VERSION_DIR}:$PATH"

# Execute cursor-agent with all arguments
exec "/opt/cursor-agent/versions/${VERSION_DIR}/cursor-agent" "$@"
