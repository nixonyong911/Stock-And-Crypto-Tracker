{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "Providers": {
    "Finnhub": {
      "ApiKey": "",
      "BaseUrl": "https://finnhub.io/api/v1",
      "RateLimitDelayMs": 2000
    },
    "AlphaVantage": {
      "ApiKey": "",
      "BaseUrl": "https://www.alphavantage.co",
      "RateLimitDelayMs": 12000,
      "Horizon": "6month"
    },
    "Massive": {
      "ApiKey": "",
      "BaseUrl": "https://api.massive.com/v1",
      "RateLimitDelayMs": 12000,
      "Timespan": "minute",
      "Limit": 390,
      "BackfillLimit": 5000,
      "BackfillDays": 90,
      "SmaWindow": 20,
      "EmaWindow": 20,
      "RsiWindow": 14,
      "MacdShortWindow": 12,
      "MacdLongWindow": 26,
      "MacdSignalWindow": 9
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "UserName": "stocktracker",
    "Password": "",
    "Port": 5672,
    "MassiveQueueName": "massive-indicator-queue"
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "data-fetcher-2.0",
    "Enabled": true,
    "TimeoutSeconds": 5
  }
}
