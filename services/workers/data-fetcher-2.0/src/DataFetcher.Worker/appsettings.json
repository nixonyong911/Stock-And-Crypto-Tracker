{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "Providers": {
    "Finnhub": {
      "ApiKey": "",
      "BaseUrl": "https://finnhub.io/api/v1",
      "RateLimitDelayMs": 2000
    },
    "AlphaVantage": {
      "ApiKey": "",
      "BaseUrl": "https://www.alphavantage.co",
      "RateLimitDelayMs": 12000,
      "Horizon": "6month"
    },
    "Massive": {
      "ApiKey": "",
      "BaseUrl": "https://api.massive.com/v1",
      "RateLimitDelayMs": 12000,
      "Timespan": "minute",
      "Limit": 390,
      "BackfillLimit": 5000,
      "BackfillDays": 90,
      "SmaWindow": 20,
      "EmaWindow": 20,
      "RsiWindow": 14,
      "MacdShortWindow": 12,
      "MacdLongWindow": 26,
      "MacdSignalWindow": 9
    },
    "CandlestickAnalysis": {
      "DaysToBackfill": 180,
      "BatchSizeDays": 30,
      "DelayBetweenDatesMs": 50,
      "DelayBetweenBatchesMs": 100
    },
    "MarketAux": {
      "ApiKey": "",
      "BaseUrl": "https://api.marketaux.com/v1",
      "DailyRequestBudget": 80
    },
    "Fred": {
      "ApiKey": "",
      "BaseUrl": "https://api.stlouisfed.org",
      "ScheduleTime": "08:00",
      "ScheduleTimezone": "America/New_York"
    },
    "Alpaca": {
      "ApiKeyId": "",
      "ApiSecretKey": "",
      "MarketDataBaseUrl": "https://data.alpaca.markets",
      "TradingApiBaseUrl": "https://api.alpaca.markets",
      "MonthsToBackfill": 6,
      "MaxBarsPerRequest": 10000,
      "StockTimeframe": "15Min",
      "CryptoTimeframe": "15Min",
      "StockFeed": "sip",
      "StockAdjustment": "split",
      "CryptoLoc": "us",
      "FetchIntervalMinutes": 30,
      "RateLimitThreshold": 10
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "UserName": "stocktracker",
    "Password": "",
    "Port": 5672,
    "MassiveQueueName": "massive-indicator-queue",
    "AnalysisBackfillQueueName": "analysis-backfill-queue",
    "BackfillQueueName": "backfill-queue",
    "CryptoBackfillQueueName": "crypto-backfill-queue"
  },
  "Gateway": {
    "BaseUrl": "http://gateway-2.0:8080",
    "InternalServiceKey": ""
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "data-fetcher-2.0",
    "Enabled": true,
    "TimeoutSeconds": 5
  }
}
