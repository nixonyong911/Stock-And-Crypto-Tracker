{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "TwelveData": {
    "ApiKey": "",
    "BaseUrl": "https://api.twelvedata.com"
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "twelvedata",
    "Enabled": true,
    "TimeoutSeconds": 5
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "UserName": "stocktracker",
    "Password": "",
    "QueueName": "backfill-queue"
  },
  "Backfill": {
    "TradingMinutesPerDay": 390,
    "TradingDaysPerMonth": 22,
    "MonthsToBackfill": 6,
    "MaxOutputSizePerRequest": 5000,
    "IntervalMinutes": 15,
    "RateLimitDelaySeconds": 8
  }
}
