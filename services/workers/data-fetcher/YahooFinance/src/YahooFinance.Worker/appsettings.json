{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "YahooFinance": {
    "DelayBetweenRequestsMs": 500,
    "MaxRetries": 5,
    "CircuitBreakerThreshold": 10,
    "CircuitBreakerDurationSeconds": 60
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "yahoofinance",
    "Enabled": true,
    "TimeoutSeconds": 5
  }
}
