{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "SimFin": {
    "ApiKey": "",
    "BaseUrl": "https://backend.simfin.com/api/v3",
    "DelayBetweenRequestsMs": 500,
    "MaxRetries": 3
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "simfin",
    "Enabled": true,
    "TimeoutSeconds": 5
  }
}
