{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stocktracker;Username=postgres;Password=postgres"
  },
  "Finnhub": {
    "ApiKey": "",
    "BaseUrl": "https://finnhub.io/api/v1",
    "RateLimitDelayMs": 2000
  },
  "MetricsService": {
    "BaseUrl": "http://metrics:8080",
    "WorkerName": "finnhub",
    "Enabled": true,
    "TimeoutSeconds": 5
  }
}
