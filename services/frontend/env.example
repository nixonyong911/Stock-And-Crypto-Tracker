# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk URLs (configured in code, but can override)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database (PostgREST via Caddy)
DATABASE_URL_JS=https://nxserver.malaysiawest.cloudapp.azure.com
DATABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (optional - when set, selects exact prices instead of auto-detecting)
# STRIPE_MONTHLY_PRICE_ID=price_xxx
# STRIPE_ANNUAL_PRICE_ID=price_xxx

# Phone verification (for trial anti-abuse - must match gateway-2.0's PHONE_HASH_SALT)
PHONE_HASH_SALT=your_random_salt_here

# Cache Revalidation (optional - for back-office cache refresh security)
# CACHE_REVALIDATE_SECRET=your_secret_key

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=https://stockandcryptotracker.com
