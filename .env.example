# ===========================================
# Stock and Crypto Tracker - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=stocktracker
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=stocktracker
DB_PORT=5432

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=3000

# ===========================================
# Alpha Vantage API (Stock Data)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# ===========================================
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Fetch interval in minutes (default: 60)
ALPHA_VANTAGE_FETCH_INTERVAL=60

# Comma-separated list of stock symbols to track
ALPHA_VANTAGE_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA

# ===========================================
# CoinGecko API (Crypto Data) - Optional
# ===========================================
# COINGECKO_API_KEY=your_coingecko_api_key_here
# COINGECKO_FETCH_INTERVAL=15

# ===========================================
# Finnhub API (Stock Data) - Optional
# ===========================================
# FINNHUB_API_KEY=your_finnhub_api_key_here
# FINNHUB_FETCH_INTERVAL=30
