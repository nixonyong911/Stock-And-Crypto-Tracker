# ===========================================
# Stock and Crypto Tracker - Environment Configuration
# ===========================================

# -----------------------------------------
# Database Connection Strings
# -----------------------------------------

# Go services (gateway-2.0) - PostgreSQL URI
DATABASE_URL_GO=postgresql://postgres:your-password@postgres:5432/stocktracker

# .NET services (data-fetcher-2.0) - ADO.NET format
DATABASE_URL_DOTNET=Host=postgres;Database=stocktracker;Username=postgres;Password=your-password

# Python services (mcp-analysis) - libpq key=value format
DATABASE_URL_PYTHON=user=postgres password=your-password host=postgres port=5432 dbname=stocktracker

# JavaScript/TypeScript services (back-office, frontend) - PostgREST base URL
DATABASE_URL_JS=https://your-server.cloudapp.azure.com

# PostgREST auth keys (JWT)
DATABASE_SERVICE_ROLE_KEY=your-service-role-jwt
DATABASE_ANON_KEY=your-anon-jwt

# -----------------------------------------
# Alpha Vantage API
# -----------------------------------------
ALPHA_VANTAGE_API_KEY=your-api-key
ALPHA_VANTAGE_FETCH_INTERVAL=60
ALPHA_VANTAGE_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA

# -----------------------------------------
# Service Ports
# -----------------------------------------
FRONTEND_PORT=3000
ALPHA_VANTAGE_API_PORT=8081
METRICS_SERVICE_PORT=8082

# -----------------------------------------
# Environment
# -----------------------------------------
NODE_ENV=production
ASPNETCORE_ENVIRONMENT=Production
