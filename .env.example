# ===========================================
# Stock and Crypto Tracker - Environment Configuration
# ===========================================

# -----------------------------------------
# Supabase Configuration (from App Frameworks tab)
# -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your-anon-key-here
SUPABASE_SECRET_DEFAULT_KEY=sb_secret_your-service-role-key-here

# -----------------------------------------
# Database Connection (from Connection String tab)
# -----------------------------------------

# For Next.js (URI format) - if using lib/db.ts for direct queries
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# For .NET services (ADO.NET format)
DATABASE_CONNECTION_STRING=User Id=postgres.your-project;Password=your-password;Server=aws-0-region.pooler.supabase.com;Port=6543;Database=postgres

# -----------------------------------------
# Alpha Vantage API
# -----------------------------------------
ALPHA_VANTAGE_API_KEY=your-api-key
ALPHA_VANTAGE_FETCH_INTERVAL=60
ALPHA_VANTAGE_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA

# -----------------------------------------
# Service Ports
# -----------------------------------------
FRONTEND_PORT=3000
ALPHA_VANTAGE_API_PORT=8081
METRICS_SERVICE_PORT=8082

# -----------------------------------------
# Environment
# -----------------------------------------
NODE_ENV=production
ASPNETCORE_ENVIRONMENT=Production